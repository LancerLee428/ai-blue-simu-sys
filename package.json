{
  "name": "ai-blue-simu-sys",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "npm --workspace @ai-blue-simu-sys/web run dev",
    "dev:server": "npm --workspace @ai-blue-simu-sys/server run dev",
    "dev": "npm run dev:server & npm run dev:web",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-cesium": "^1.2.23"
  }
}
